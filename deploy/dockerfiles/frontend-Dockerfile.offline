# TestAgent Frontend Dockerfile（离线构建版）
# 适用于无互联网的内网环境
#
# 构建前提：
#   offline-npm-cache/frontend/npm-cache/ - npm 离线缓存
#
# Build context: TestAgent/（项目根目录）
# docker compose -f deploy/docker-compose.prod.yml build frontend

# ─── 阶段1: 构建 ─────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY Client/frontend/package*.json ./

# 使用离线 npm 缓存
COPY offline-npm-cache/frontend/npm-cache /root/.npm
RUN npm ci --prefer-offline

COPY Client/frontend/ ./

RUN npm run build

# ─── 阶段2: 运行（Nginx 托管静态文件）────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html

# 使用项目内 nginx 配置
COPY k8s/nginx.conf /etc/nginx/conf.d/default.conf

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:80/health || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
