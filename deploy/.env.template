# TestAgent 内网部署环境变量模板
# 复制此文件为 .env 并填写配置后，再执行 docker compose 构建
# cp deploy/.env.template .env

# ─── LLM 配置（必填）────────────────────────────────────────────────────────
# 内网 LLM 提供商标识（待开发适配器后填写，如 intranet / custom 等）
LLM_PROVIDER=dashscope

# 内网模型名称
LLM_MODEL_NAME=qwen3-max

# 内网 Access Key（纯数字，内网 LLM 认证凭证）
LLM_API_KEY=your-access-key-here

# 内网 LLM API 基础 URL（如有，留空则使用 Provider 默认值）
# LLM_BASE_URL=http://internal-llm-server:8080/v1

# ─── 数据库配置 ──────────────────────────────────────────────────────────────
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password
POSTGRES_DB=testagent

# ─── Redis 配置 ──────────────────────────────────────────────────────────────
# (默认无密码，内网环境可接受)

# ─── 应用安全配置 ─────────────────────────────────────────────────────────────
# JWT 密钥（建议修改为随机字符串）
JWT_SECRET=change-this-to-a-random-secret-in-production

# ─── 服务端口（可按需修改）───────────────────────────────────────────────────
# FRONTEND_PORT=39999
# SERVER_PORT=39998
# CODE_INDEX_PORT=40001

# ─── CORS（内网可放开，或指定内网 IP）────────────────────────────────────────
CORS_ORIGIN=*

# ─── 日志级别 ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
